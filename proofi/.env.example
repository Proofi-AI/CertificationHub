# ============================================================
# PROOFI AI — ENVIRONMENT VARIABLES REFERENCE
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# For local development, use your DEVELOPMENT Supabase project.
# For production, add these variables in Vercel dashboard.
# ============================================================

# Supabase Project
# Get these from: supabase.com > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database URLs — BOTH are required for Prisma + Supabase to work correctly
# DATABASE_URL: uses Supabase connection pooler (port 6543) — used at runtime
# DIRECT_URL: uses direct Postgres connection (port 5432) — used for migrations only
# Get both from: supabase.com > your project > Settings > Database
DATABASE_URL=
DIRECT_URL=

# App URL
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=

# Contact Form — Gmail SMTP
# CONTACT_EMAIL_PASS must be a Gmail App Password, NOT your regular Gmail password
# Generate one at: myaccount.google.com > Security > 2-Step Verification > App Passwords
CONTACT_EMAIL_USER=
CONTACT_EMAIL_PASS=

# AI Features
# Get free key from: aistudio.google.com
GEMINI_API_KEY=

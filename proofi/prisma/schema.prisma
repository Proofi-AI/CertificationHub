generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id           String        @id
  email        String        @unique
  name         String?
  bio          String?
  avatarUrl    String?
  slug         String        @unique
  defaultTheme String        @default("dark")
  features     Json          @default("{}")
  isAdmin      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  certificates Certificate[]
  feedbacks    Feedback[]
}

model Certificate {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  issuer       String
  issuedAt     DateTime
  expiresAt    DateTime?
  domain       String
  credentialId String?
  imageUrl     String?
  isPublic     Boolean   @default(true)
  verifyStatus String    @default("self_reported")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model Feedback {
  id        String   @id @default(cuid())
  type      String   // 'bug', 'feature', 'general'
  name      String?
  email     String?
  message   String
  metadata  Json     @default("{}") // for OS, browser, URL
  imageUrl  String?
  priority  String?  // 'low', 'medium', 'high'
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  status    String   @default("open") // open, in-progress, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
